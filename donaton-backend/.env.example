# Copiar este archivo como .env y completar con los valores reales de AWS Academy

# RDS PostgreSQL
DB_URL=jdbc:postgresql://<RDS-ENDPOINT>:5432/donaton
DB_USERNAME=postgres
DB_PASSWORD=tu_password

# Amazon MQ (RabbitMQ)
RABBITMQ_HOST=<AMAZOMQ-ENDPOINT>
RABBITMQ_PORT=5671
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=tu_password
RABBITMQ_SSL=true

# JWT (cambiar por una clave segura de al menos 32 caracteres)
JWT_SECRET=cambia_esto_por_una_clave_segura_de_32chars!
JWT_EXPIRATION=86400000
