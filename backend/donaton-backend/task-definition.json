{
  "family": "donaton-backend-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::532149873618:role/LabRole",
  "taskRoleArn": "arn:aws:iam::532149873618:role/LabRole",
  "containerDefinitions": [
    {
      "name": "donaton-backend-container",
      "image": "532149873618.dkr.ecr.us-west-2.amazonaws.com/donaton-backend:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "AUTH_HOST", "value": "127.0.0.1"}
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/donaton-backend",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "donaton-auth-container",
      "image": "532149873618.dkr.ecr.us-west-2.amazonaws.com/donaton-auth:latest",
      "portMappings": [
        {
          "containerPort": 8081,
          "hostPort": 8081,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "DB_URL", "value": "jdbc:postgresql://127.0.0.1:5432/donaton"},
        {"name": "DB_USERNAME", "value": "root"},
        {"name": "DB_PASSWORD", "value": "password"},
        {"name": "RABBITMQ_HOST", "value": "127.0.0.1"},
        {"name": "RABBITMQ_PORT", "value": "5672"},
        {"name": "RABBITMQ_USERNAME", "value": "guest"},
        {"name": "RABBITMQ_PASSWORD", "value": "guest"},
        {"name": "JWT_SECRET", "value": "donaton_secret_key_must_be_at_least_32_chars_long!"}
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/donaton-backend",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "postgres-container",
      "image": "postgres:15",
      "portMappings": [
        {
          "containerPort": 5432,
          "hostPort": 5432,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "POSTGRES_USER", "value": "root"},
        {"name": "POSTGRES_PASSWORD", "value": "password"},
        {"name": "POSTGRES_DB", "value": "donaton"}
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/donaton-backend",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "rabbitmq-container",
      "image": "rabbitmq:3-management",
      "portMappings": [
        {
          "containerPort": 5672,
          "hostPort": 5672,
          "protocol": "tcp"
        },
        {
          "containerPort": 15672,
          "hostPort": 15672,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "RABBITMQ_DEFAULT_USER", "value": "guest"},
        {"name": "RABBITMQ_DEFAULT_PASS", "value": "guest"}
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/donaton-backend",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048"
}
