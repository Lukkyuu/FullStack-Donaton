{
  "family": "donaton-backend-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::532149873618:role/LabRole",
  "taskRoleArn": "arn:aws:iam::532149873618:role/LabRole",
  "containerDefinitions": [
    {
      "name": "donaton-backend-container",
      "image": "532149873618.dkr.ecr.us-west-2.amazonaws.com/donaton-backend:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "AUTH_HOST", "value": "127.0.0.1"},
        {"name": "DONACION_HOST", "value": "127.0.0.1"},
        {"name": "LOGISTICA_HOST", "value": "127.0.0.1"},
        {"name": "NECESIDAD_HOST", "value": "127.0.0.1"},
        {"name": "USUARIOS_HOST", "value": "127.0.0.1"},
        {"name": "MATCHING_HOST", "value": "127.0.0.1"},
        {"name": "NOTIFICACIONES_HOST", "value": "127.0.0.1"}
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/donaton-backend",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "donaton-auth-container",
      "image": "532149873618.dkr.ecr.us-west-2.amazonaws.com/donaton-auth:latest",
